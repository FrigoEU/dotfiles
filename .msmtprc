# msmtp config for sending mail.
# Auth: app password from .secrets (env var GOOGLE_APP_PASSWORD).
# Generate at https://myaccount.google.com/apppasswords
#
# msmtp REQUIRES this file to be mode 0600. Symlink target counts —
# i.e. ~/dotfiles/.msmtprc itself must be 0600.

defaults
auth           on
tls            on
tls_starttls   on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.cache/msmtp.log

account gmail
host    smtp.gmail.com
port    587
from    simon.van.casteren@gmail.com
user    simon.van.casteren@gmail.com
# Read password from the env (same source mbsync uses).
# emacs must inherit GOOGLE_APP_PASSWORD when it spawns msmtp.
passwordeval  printf '%s' "$GOOGLE_APP_PASSWORD"

account default : gmail
